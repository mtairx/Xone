# Copy this file to .env and fill in real values before going live.

# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Used to sign buyer session tokens — use a long random string in production
JWT_SECRET=change-this-to-something-random-and-long

# Where Stripe Checkout redirects back to after payment
FRONTEND_URL=http://localhost:8911

PORT=4242
